# =====================================================
# BIJOUTERIE NADOR — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =====================================================

# --- Base de données (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:PASSWORD@db.SUPABASE_ID.supabase.co:5432/postgres"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-cle-secrete-tres-longue-et-aleatoire"

# --- Stripe (mode test) ---
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="votre_api_key"
CLOUDINARY_API_SECRET="votre_api_secret"

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY="votre_cle_google_maps"

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER="212600000000"

# --- Email (Nodemailer / Gmail SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="votre@email.com"
SMTP_PASS="votre_mot_de_passe_application"
EMAIL_FROM="Bijouterie Nador <noreply@bijouterie-nador.com>"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Bijouterie Nador"
