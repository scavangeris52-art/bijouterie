# =====================================================
# BIJOUTERIE NADOR — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =====================================================

# === DATABASE ===
# PostgreSQL connection string (Supabase, Railway, Vercel Postgres, etc.)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://postgres:PASSWORD@db.SUPABASE_ID.supabase.co:5432/postgres?sslmode=require"

# === NEXTAUTH CONFIGURATION ===
# The URL where your app is deployed (used for callbacks)
NEXTAUTH_URL="http://localhost:3000"
# IMPORTANT: Generate a strong secret using: openssl rand -base64 32
# This is REQUIRED for production. Without it, auth will fail.
NEXTAUTH_SECRET="your-super-secure-random-string-generated-with-openssl-rand-base64-32"

# === STRIPE PAYMENT ===
# Test keys from https://dashboard.stripe.com/apikeys
# Production keys should be used in production environment
STRIPE_SECRET_KEY="sk_test_51234567890abcdefghijklmnop"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51234567890abcdefghijklmnop"
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_1234567890abcdefghijklmnop"

# === CLOUDINARY IMAGE STORAGE ===
# Image upload and hosting service
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# === EMAIL SERVICE ===
# Option 1: Gmail SMTP (requires App Password, not regular Gmail password)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
EMAIL_FROM="Bijouterie Nador <noreply@bijouterie-nador.com>"

# Alternative: Resend (https://resend.com)
# RESEND_API_KEY="re_1234567890abcdefghijklmnop"

# === GOOGLE MAPS (Optional) ===
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIzaSyD1234567890abcdefghijklmnop"

# === WHATSAPP (Optional) ===
# International format without + sign
NEXT_PUBLIC_WHATSAPP_NUMBER="212600000000"

# === APPLICATION SETTINGS ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Bijouterie Nador"

# === DEVELOPMENT ===
# Set to 'development' or 'production'
NODE_ENV="development"
